# Copy to .env and fill in (never commit .env)
FLASK_APP=app
FLASK_ENV=development
SECRET_KEY=change-me-in-production
# Local dev: omit DATABASE_URL to use SQLite at instance/neighborfix.db
# Railway Postgres often provides postgres:// — the app normalizes it for SQLAlchemy.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
