# Copy to .env and fill in (never commit .env)
FLASK_APP=app
FLASK_ENV=development
SECRET_KEY=change-me-in-production
# Staff dashboard at /admin — set a strong password (updates issues.status in the DB)
# ADMIN_PASSWORD=choose-a-long-random-secret
# Local dev: omit DATABASE_URL to use SQLite at instance/neighborfix.db
# Railway Postgres often provides postgres:// — the app normalizes it for SQLAlchemy.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
